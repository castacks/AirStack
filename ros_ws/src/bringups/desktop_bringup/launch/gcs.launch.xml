<!-- GCS OFFBOARD -->
<launch>
  <!-- ====== ARGS ====== -->
  <arg name="sim" default="true" />
  <arg name="record_bag" default="$(env RECORD_BAGS)" />

  <!-- set "onboard_all" or "onboard_local_offboard_global" -->
  <arg name="autonomy_split_type" default="onboard_all" />

  <!-- ====== AUTONOMY ====== -->

  <!-- onboard all -->
  <group if="$(eval var autonomy_split_type == 'onboard_all')">
    <!-- no autonomy -->
  </group>

  <!-- onboard local offboard global -->
  <group if="$(eval var autonomy_split_type == 'onboard_local_offboard_global')">
    <include
      file="$(find-pkg-share autonomy_bringup)/onboard_local_offboard_global/launch/offboard_autonomy_global.launch.xml">
      <arg name="launch_global_to_gcs_domain_bridge" value="true" />
    </include>
  </group>

  <!-- ======== GUI ======== -->

  <node pkg="rviz2" exec="rviz2"
    args="-d $(find-pkg-share gcs_bringup)/rviz/gcs.rviz --ros-args --log-level INFO"
    output="screen" respawn="true" respawn_delay="1" />

  <node pkg="rqt_gui" exec="rqt_gui"
    args="--perspective-file $(find-pkg-share gcs_bringup)/config/gcs.perspective --ros-args --log-level INFO"
    output="screen" respawn="true" respawn_delay="1" />

  <node pkg="domain_bridge" exec="domain_bridge"
    args="$(find-pkg-share gcs_bringup)/config/domain_bridge.yaml">
  </node>

  <!-- ===================== -->

</launch>