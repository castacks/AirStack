<!-- ROBOT -->
<launch>

  <arg name="sim" default="true" />
  <arg name="record_bag" default="$(env RECORD_BAGS)" />

  <push_ros_namespace namespace="$(env ROBOT_NAME)" />

  <set_parameter name="use_sim_time" value="true" if="$(var sim)" />

  <!-- Sim -->
  <group if="$(var sim)">
    <include file="$(find-pkg-share desktop_bringup)/launch/sim.launch.xml" />
  </group>
  <!-- Real -->
  <group unless="$(var sim)">
    <include file="$(find-pkg-share desktop_bringup)/launch/real.launch.xml" />
  </group>

  <!-- Robot State Publisher (replaces static transforms) -->
  <include file="$(find-pkg-share desktop_bringup)/launch/robot_state_publisher.launch.py">
    <arg name="robot_name" value="$(env ROBOT_NAME)" />
    <arg name="urdf_file_path" value="$(env ROBOT_URDF_FILE_PATH)" />
    <arg name="ignore_timestamp" value="true" />
    <arg name="use_sim_time" value="$(var sim)" />
  </include>

  <!-- Static TFs for simulation connection -->
  <include file="$(find-pkg-share desktop_bringup)/launch/static_transforms.launch.xml">
    <arg name="robot_namespace" value="$(env ROBOT_NAME)" />
  </include>

  <!-- Autonomy Stack - Module Bringups -->
  <!-- Interface -->
  <include file="$(find-pkg-share interface_bringup)/launch/interface.launch.xml" />

  <!-- Sensors -->
  <include file="$(find-pkg-share sensors_bringup)/launch/sensors.launch.xml" />

  <!-- Perception -->
  <include file="$(find-pkg-share perception_bringup)/launch/perception.launch.xml" />

  <!-- Local -->
  <include file="$(find-pkg-share local_bringup)/launch/local.launch.xml" />

  <!-- Global -->
  <include file="$(find-pkg-share global_bringup)/launch/global.launch.xml" />

  <!-- Behavior -->
  <include file="$(find-pkg-share behavior_bringup)/launch/behavior.launch.xml" />

  <!-- Logging -->
  <include file="$(find-pkg-share logging_bringup)/launch/logging.launch.xml" />

  <!-- Domain Bridge -->
  <node pkg="domain_bridge" exec="domain_bridge"
    args="$(find-pkg-share desktop_bringup)/params/domain_bridge.yaml"
    output="screen" respawn="true" respawn_delay="1" />

</launch>
