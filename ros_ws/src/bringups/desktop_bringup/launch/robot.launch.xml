<!-- Desktop / sim wrapper: delegates to autonomy_bringup and adds RViz. -->
<launch>
  <arg name="sim"       default="true" />
  <arg name="role"      default="$(env AUTONOMY_ROLE full)" />
  <arg name="urdf_file" default="iris/urdf/iris_with_sensors.pegasus.robot.urdf" />

  <!-- Core robot launch (state publisher, static TFs, autonomy modules) -->
  <include file="$(find-pkg-share autonomy_bringup)/launch/robot.launch.xml">
    <arg name="sim"      value="$(var sim)" />
    <arg name="role"     value="$(var role)" />
    <arg name="urdf_file" value="$(var urdf_file)" />
  </include>

  <!-- Visualization: only in sim/desktop environments -->
  <group if="$(var sim)">
    <node pkg="rviz2" exec="rviz2"
      args="-d $(find-pkg-share desktop_bringup)/rviz/robot.rviz --ros-args --log-level INFO"
      output="screen" respawn="true" respawn_delay="1" />
  </group>

</launch>
