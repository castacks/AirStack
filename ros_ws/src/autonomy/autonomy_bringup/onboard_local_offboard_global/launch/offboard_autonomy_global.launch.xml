<!-- ROBOT -->
<launch>
  <arg name="launch_global_to_gcs_domain_bridge" default="true" />

  <!-- Autonomy Stack - Module Bringups -->
  <!-- Only global runs offboard; all other packages are disabled -->
  <include file="$(find-pkg-share autonomy_bringup)/onboard_all/launch/onboard_autonomy_all.launch.xml">
    <arg name="interface_package" value="" />
    <arg name="sensors_package" value="" />
    <arg name="perception_package" value="" />
    <arg name="local_package" value="" />
    <arg name="behavior_package" value="" />
    <arg name="logging_package" value="" />
  </include>

  <group if="$(var launch_global_to_gcs_domain_bridge)">
    <!-- Domain Bridge -->
    <node pkg="domain_bridge" exec="domain_bridge"
      args="$(find-pkg-share autonomy_bringup)/onboard_local_offboard_global/config/global_to_gcs.domain_bridge.yaml"
      output="screen" respawn="true" respawn_delay="1" />
  </group>

</launch>
