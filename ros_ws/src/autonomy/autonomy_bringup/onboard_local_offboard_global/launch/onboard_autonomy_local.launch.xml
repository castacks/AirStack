<!-- ROBOT -->
<launch>
  <arg name="launch_onboard_to_offboard_domain_bridge" default="true" />

  <!-- Autonomy Stack - Module Bringups -->
  <!-- Global and logging are not run onboard in this configuration -->
  <include file="$(find-pkg-share autonomy_bringup)/onboard_all/launch/onboard_autonomy_all.launch.xml">
    <!-- set global and logging package to nothing  -->
    <arg name="global_package" value="" />
    <arg name="logging_package" value="" />
  </include>

  <group if="$(var launch_onboard_to_offboard_domain_bridge)">
    <!-- Domain Bridge -->
    <include file="$(find-pkg-share autonomy_bringup)/launch/interpolate_domain_bridge.launch.py" >
      <arg name="config_file" value="$(find-pkg-share autonomy_bringup)/onboard_local_offboard_global/config/onboard_to_offboard.domain_bridge.yaml" />
      <arg name="args" value="gcs_domain:=0" />
    </include>
  </group>


</launch>
