<!-- ROBOT -->
<launch>

  <!-- Autonomy Stack - Module Bringups -->
  <!-- Interface -->
  <include file="$(find-pkg-share interface_bringup)/launch/interface.launch.xml" />

  <!-- Sensors -->
  <include file="$(find-pkg-share sensors_bringup)/launch/sensors.launch.xml" />

  <!-- Perception -->
  <include file="$(find-pkg-share perception_bringup)/launch/perception.launch.xml" />

  <!-- Local -->
  <include file="$(find-pkg-share local_bringup)/launch/local.launch.xml" />

  <!-- Global -->
  <include file="$(find-pkg-share global_bringup)/launch/global.launch.xml" />

  <!-- Behavior -->
  <include file="$(find-pkg-share behavior_bringup)/launch/behavior.launch.xml" />

  <!-- Logging -->
  <include file="$(find-pkg-share logging_bringup)/launch/logging.launch.xml" />

  <!-- Domain Bridge -->
  <node pkg="domain_bridge" exec="domain_bridge"
    args="$(find-pkg-share autonomy_bringup)/onboard_all/config/domain_bridge.yaml"
    output="screen" respawn="true" respawn_delay="1" />

</launch>
