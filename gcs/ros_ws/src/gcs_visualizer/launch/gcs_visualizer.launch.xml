<launch>
  <arg name="robot_name_prefix" default="robot" />

  <!-- Standard visualization: mesh, labels, axes, trajectory, global plan, VDB -->
  <node pkg="gcs_visualizer" exec="foxglove_visualizer_node" name="foxglove_visualizer_node" output="screen">
    <param name="robot_name_prefix" value="$(var robot_name_prefix)" />
  </node>

  <!-- Payload visualization: project-specific data from PeerProfile gossip payloads -->
  <!-- Remove or replace this node for projects that don't use Rayfronts -->
  <node pkg="gcs_visualizer" exec="payload_visualizer_node" name="payload_visualizer_node" output="screen" />
</launch>
