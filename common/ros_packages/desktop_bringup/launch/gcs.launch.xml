<!-- GCS OFFBOARD -->
<launch>
  <!-- ====== ARGS ====== -->
  <arg name="sim" default="true" />
  <arg name="record_bag" default="$(env RECORD_BAGS)" />

  <!-- set "onboard_all" or "onboard_local_offboard_global" -->
  <arg name="autonomy_split_type" default="onboard_all" />

  <!-- ======== GUI ======== -->

  <?ignore
  <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share desktop_bringup)/rviz/gcs.rviz --ros-args --log-level INFO" output="screen" respawn="true" respawn_delay="1" />
    ?>
  <!-- ===================== -->

</launch>