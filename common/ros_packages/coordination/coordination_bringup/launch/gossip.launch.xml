<!-- Gossip coordination layer bringup.
     Starts the gossip_node. Under rmw_zenoh_cpp all containers share a single
     graph (ROS_DOMAIN_ID=0) via the Zenoh router in the GCS container, so no
     dedicated DDS Router bridge for gossip is needed. The gossip_domain and
     publish_rate args are retained for launch compatibility but gossip_domain
     is a no-op.
-->
<launch>
  <arg name="gossip_domain"  default="99" />
  <arg name="publish_rate"   default="1.0" />

  <!-- Gossip node -->
  <node pkg="coordination_bringup" exec="gossip_node" name="gossip_node" output="screen">
    <param name="robot_name"            value="$(env ROBOT_NAME)" />
    <param name="publish_rate"          value="$(var publish_rate)" />
    <param name="payload_topics_config" value="$(find-pkg-share coordination_bringup)/config/gossip_payloads.yaml" />
  </node>
</launch>
