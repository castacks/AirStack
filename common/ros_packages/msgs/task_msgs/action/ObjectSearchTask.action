# Search an area for instances of a specified object class.
# target_count: stop after finding this many objects (0 = find all within area/time)
# time_limit_sec: maximum task duration in seconds (0 = no limit)

# Goal
string object_class
geometry_msgs/Polygon search_area
float32 min_altitude_agl
float32 max_altitude_agl
float32 min_flight_speed
float32 max_flight_speed
float32 time_limit_sec
int32 target_count
---
# Result
bool success
string message
int32 objects_found
geometry_msgs/PoseArray object_poses
---
# Feedback
string status
float32 progress
int32 objects_found_so_far
geometry_msgs/Point current_position
