<?xml version="1.0"?>
<launch>
  <!--
    Vision Pose Converter Launch File

    Optional bridge that re-publishes NatNet pose_cov data on the MAVROS
    vision_pose topics so PX4 can fuse external pose estimates.

    Static params (frame_id, child_frame_id, default use_sim_time): config/vision_pose_converter.yaml
    Topic wiring still uses body_name + ROBOT_NAME below.

    Input  (from NatNet node):
      /{ROBOT_NAME}/perception/optitrack/{body_name}/pose_cov

    Output (consumed by MAVROS):
      /{ROBOT_NAME}/mavros/vision_pose/pose
      /{ROBOT_NAME}/mavros/vision_pose/pose_cov
  -->

  <arg name="config_file"
       default="$(find-pkg-share natnet_ros2)/config/vision_pose_converter.yaml"
       description="ROS 2 parameter YAML (/** ros__parameters block)"/>

  <arg name="body_name" default="robot_1"
       description="Body name matching NatNet topic suffix (must match natnet_config.yaml)"/>

  <!-- Overrides vision_pose_converter.yaml use_sim_time when launching from sim -->
  <arg name="use_sim_time" default="false"
       description="Forwarded after YAML so sim stacks can force true"/>

  <node pkg="natnet_ros2" exec="vision_pose_converter_node.py"
        name="vision_pose_converter" output="screen">
    <param from="$(var config_file)" allow_substs="true"/>

    <remap from="input_pose"
           to="/$(env ROBOT_NAME robot_1)/perception/optitrack/$(var body_name)/pose_cov"/>
    <remap from="output_pose"
           to="/$(env ROBOT_NAME robot_1)/mavros/vision_pose/pose"/>
    <remap from="output_pose_cov"
           to="/$(env ROBOT_NAME robot_1)/mavros/vision_pose/pose_cov"/>

    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

</launch>
