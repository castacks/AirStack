<launch>
  <arg name="config_name" default="low_memory"/>
  <arg name="dataset"     default="ros2isaacsim"/>
  <arg name="query_period" default="10"/>

  <!--
    Bridge: republish nav_msgs/Odometry as geometry_msgs/PoseStamped so rayfronts
    (which only knows PoseStamped on its pose_topic) can consume our odometry
    stream. Avoids any submodule-level patch to rayfronts/datasets/ros.py.
  -->
  <node pkg="perception_bringup" exec="odom_to_pose_stamped.py"
        name="odom_to_pose_stamped" output="screen"/>

  <executable
    cmd="python3 -m rayfronts.mapping_server
         --config-name $(var config_name)
         dataset=$(var dataset)
         messaging_service=ros
         querying.text_query_mode=prompts
         querying.query_file=null
         querying.compute_prob=True
         querying.period=$(var query_period)"
    cwd="/opt/rayfronts"
    output="screen">
    <env name="HYDRA_FULL_ERROR" value="1"/>
  </executable>
</launch>
