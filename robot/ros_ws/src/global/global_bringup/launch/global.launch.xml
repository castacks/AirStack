<!-- GLOBAL -->
<launch>
    <!-- World Model -->
    <include file="$(find-pkg-share vdb_mapping_ros2)/launch/vdb_mapping_ros2.py" >
        <arg name="config" value="$(find-pkg-share global_bringup)/config/vdb_params.yaml" />
    </include>

    <!-- Planning -->
    <node pkg="random_walk_planner" exec="random_walk_planner" name="random_walk_planner"
        output="screen">
        <param from="$(find-pkg-share random_walk_planner)/config/random_walk_config.yaml" />
        <remap from="vdb_map_visualization" to="/$(env ROBOT_NAME)/vdb_mapping/vdb_map_visualization" />
        <remap from="~/global_plan" to="/$(env ROBOT_NAME)/global_plan" />
        <remap from="~/exploration_task" to="/$(env ROBOT_NAME)/tasks/exploration" />
        <remap from="navigate_task" to="/$(env ROBOT_NAME)/tasks/navigate" />
        <remap from="odometry" to="/$(env ROBOT_NAME)/odometry_conversion/odometry" />
    </node>

    <!-- Coverage Planner (boustrophedon / lawn-mower) -->
    <node pkg="coverage_planner" exec="coverage_planner" name="coverage_planner"
        output="screen">
        <param from="$(find-pkg-share coverage_planner)/config/coverage_planner_config.yaml"
               allow_substs="true" />
        <remap from="~/global_plan" to="/$(env ROBOT_NAME)/global_plan" />
        <remap from="~/coverage_task" to="/$(env ROBOT_NAME)/tasks/coverage" />
        <remap from="navigate_task" to="/$(env ROBOT_NAME)/tasks/navigate" />
        <remap from="odometry" to="/$(env ROBOT_NAME)/odometry_conversion/odometry" />
    </node>

</launch>
