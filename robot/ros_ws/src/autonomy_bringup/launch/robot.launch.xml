<!-- Single entry point for all robot deployments.
     role choices:
       full     - all autonomy modules run on this machine (default: sim/dev desktop, autonomous Jetson)
       onboard  - lite modules only: interface, sensors, perception, local planning, behavior (VOXL, Jetson
lite, desktop_split sim)
       offboard - global planning only: runs on GCS paired with onboard robots (robot-offboard service)
-->
<launch>
  <arg name="sim" default="true" />
  <arg name="role" default="$(env AUTONOMY_ROLE full)" />
  <arg name="urdf_file" default="$(env URDF_FILE)" />
  <arg name="gcs_domain" default="0" />
  <arg name="gossip_domain" default="99" />
  <arg name="gossip_publish_rate" default="1.0" />

  <push_ros_namespace namespace="$(env ROBOT_NAME)" />

  <!-- tf2 and rviz tool outputs publish to absolute names, which collide when every
       container shares one Zenoh graph. Remap to an *absolute* per-robot topic —
       NOT a relative one — because many autonomy nodes live under sub-namespaces
       (mavros at /ROBOT/interface/mavros, droan at /ROBOT/droan, etc.) and a
       relative target would compound into /ROBOT/sub/tf instead of /ROBOT/tf.
       Pre-Zenoh this wasn't needed because each robot was on its own ROS_DOMAIN_ID
       and DDS isolated them. -->
  <set_remap from="/tf"                    to="/$(env ROBOT_NAME)/tf" />
  <set_remap from="/tf_static"             to="/$(env ROBOT_NAME)/tf_static" />
  <set_remap from="/clicked_point"         to="/$(env ROBOT_NAME)/clicked_point" />
  <set_remap from="/goal_pose"             to="/$(env ROBOT_NAME)/goal_pose" />
  <set_remap from="/initialpose"           to="/$(env ROBOT_NAME)/initialpose" />
  <set_remap from="/move_base_simple/goal" to="/$(env ROBOT_NAME)/move_base_simple/goal" />

  <set_parameter name="use_sim_time" value="true" if="$(var sim)" />

  <!-- Robot State Publisher -->
  <include file="$(find-pkg-share robot_descriptions)/launch/robot_state_publisher.launch.py">
    <arg name="robot_name" value="$(env ROBOT_NAME)" />
    <arg name="urdf_file_path" value="$(var urdf_file)" />
    <arg name="ignore_timestamp" value="true" />
    <arg name="use_sim_time" value="$(var sim)" />
  </include>

  <!-- Static TFs (world → map) -->
  <node pkg="tf2_ros" exec="static_transform_publisher"
    name="world_to_map_broadcaster"
    args="0 0 0 0 0 0 world map" />

  <!-- ── Role dispatch ───────────────────────────────────────────────── -->

  <!-- Under rmw_zenoh_cpp (since the Zenoh migration) all containers share ROS_DOMAIN_ID=0
       and the Zenoh router running in the GCS container provides discovery across containers.
       No per-role ddsrouter instance is launched here anymore. -->

  <!-- full: every autonomy module runs here -->
  <group if="$(eval '&quot;$(var role)&quot; == &quot;full&quot;')">
    <include
      file="$(find-pkg-share autonomy_bringup)/onboard_all/launch/onboard_autonomy_all.launch.xml" />

    <!-- Gossip coordination layer -->
    <include file="$(find-pkg-share coordination_bringup)/launch/gossip.launch.xml">
      <arg name="gossip_domain"  value="$(var gossip_domain)" />
      <arg name="publish_rate"   value="$(var gossip_publish_rate)" />
    </include>
  </group>

  <!-- onboard: lite modules only (local planning, perception, etc.); global is handled offboard -->
  <group if="$(eval '&quot;$(var role)&quot; == &quot;onboard&quot;')">
    <include
      file="$(find-pkg-share autonomy_bringup)/onboard_local_offboard_global/launch/onboard_autonomy_local.launch.xml" />

    <!-- Gossip coordination layer -->
    <include file="$(find-pkg-share coordination_bringup)/launch/gossip.launch.xml">
      <arg name="gossip_domain"  value="$(var gossip_domain)" />
      <arg name="publish_rate"   value="$(var gossip_publish_rate)" />
    </include>

  </group>

  <!-- offboard: global planning only; runs on GCS paired with onboard robots -->
  <group if="$(eval '&quot;$(var role)&quot; == &quot;offboard&quot;')">
    <include
      file="$(find-pkg-share autonomy_bringup)/onboard_local_offboard_global/launch/offboard_autonomy_global.launch.xml" />
  </group>

</launch>